[Unit]
Description=ITAgent Flask Web Application (Gunicorn)
After=itagent-db.service network.target
Wants=itagent-db.service

[Service]
Type=simple
User=root
EnvironmentFile=/etc/default/itagent
ExecStartPre=/bin/bash -c "for i in $(seq 1 30); do curl -s http://127.0.0.1:27017/ >/dev/null 2>&1 && exit 0; sleep 2; done; echo MongoDB not ready but proceeding anyway"
# 變更 #40 (v3.5.0.0): 從 Flask dev server 改為 Gunicorn (4 worker, 300s timeout)
#   -w 4              : 4 個 worker process，可支撐 500-2000 台規模下多使用者同時用
#   --timeout 300     : 配合最長請求 (全修 fix-all 內部 timeout 300s)
#   --graceful-timeout 30 : reload 時優雅關閉等 30 秒
# rollback: /opt/inspection/scripts/rollback_to_flask_dev.sh
ExecStart=/bin/bash -c "cd ${ITAGENT_HOME}/webapp && /usr/local/bin/gunicorn -w 4 -b 127.0.0.1:5000 --timeout 300 --graceful-timeout 30 --access-logfile - --error-logfile - app:app"
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
