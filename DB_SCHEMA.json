{
  "_comment": "MongoDB inspection 資料庫 — Collection Schema 範例文件。",
  "_WARNING_STALE": "本檔停在 v3.4.2 時代！v3.11.2 新增約 10 個 collection 未列出（audit_accounts/filter_rules/feature_flags/twgcb_scans/twgcb_daily_stats/security_audit/nmon_timeseries/packages/patch_queue/action_logs 等）。實際 schema 以 AI/webapp/models/*.py 與運行中 MongoDB 為準。",
  "_SEE_ALSO": "DEVELOPER.md §8 有 v3.11.2 最新 collection 列表。",
  "database": "inspection",
  "connection": "mongodb://127.0.0.1:27017/inspection",

  "collections": {

    "hosts": {
      "_comment": "受監控主機清單，hostname 為唯一鍵",
      "sample": {
        "hostname": "SECSVR019",
        "ip": "<TARGET_HOST>",
        "os": "Rocky Linux 9.7",
        "os_group": "rocky",
        "status": "使用中",
        "environment": "正式",
        "group": "Web Servers",
        "has_python": true,
        "asset_seq": "AST-2024-0019",
        "asset_name": "網站伺服器",
        "division": "資訊處",
        "department": "系統部",
        "owner": "系統部",
        "custodian": "王大明",
        "custodian_ad": "dmwang",
        "system_type": "gold",
        "ap_owner": "陳小華",
        "imported_at": "2026-04-01T08:00:00",
        "updated_at": "2026-04-18T06:30:00"
      },
      "indexes": [
        {"key": {"hostname": 1}, "unique": true}
      ]
    },

