        {"key": {"hostname": 1, "run_date": -1, "run_time": -1}},
        {"key": {"run_date": -1}},
        {"key": {"overall_status": 1}}
      ]
    },

    "filter_rules": {
      "_comment": "過濾規則，用於標記已知問題減少誤報",
      "sample": {
        "rule_id": "6612a3b4c5d6e7f8a9b0c1d2",
        "name": "已知的日誌輪替錯誤",
        "type": "keyword",
        "pattern": "failed to rotate log",
        "apply_to": "all",
        "enabled": true,
        "is_known_issue": true,
        "known_issue_reason": "logrotate 設定問題，已排入下次維護窗口修復",
        "hit_count": 42,
        "created_at": "2026-04-10T10:00:00",
        "updated_at": "2026-04-15T14:30:00"
      }
    },

    "settings": {
      "_comment": "系統設定，key-value 結構",
      "samples": [
        {
          "key": "thresholds",
          "value": {
            "disk_warn": 85, "disk_crit": 95,
            "cpu_warn": 80, "cpu_crit": 95,
            "mem_warn": 80, "mem_crit": 95
          }
        },
        {
          "key": "disk_exclude_mounts",
          "value": ["/dev", "/run", "/sys", "/proc", "/tmp"]
        },
        {
          "key": "disk_exclude_prefixes",
          "value": ["/run/", "/dev/", "/sys/", "/proc/", "/var/lib/containers/"]
        },
        {
          "key": "service_check_list",
          "value": ["sshd", "crond"]
        },
        {
          "key": "notify_email",
          "value": {
            "enabled": true,
            "smtp_host": "smtp.gmail.com",
            "smtp_port": 587,
            "smtp_user": "alert@company.com",
            "smtp_pass": "ENV:SMTP_PASSWORD",
            "recipients": ["admin@company.com"]
          }
        }
      ]
    },

    "users": {
      "_comment": "使用者帳號，username 唯一。角色：superadmin / admin / oper",
      "sample": {
        "username": "admin",
        "password_hash": "$2b$12$...(bcrypt hash)...",
        "display_name": "系統管理員",
        "role": "admin",
        "must_change_password": false,
        "last_seen": "2026-04-18T09:15:30",
        "last_ip": "<ADMIN_HOST>",
        "email": "admin@company.com"
