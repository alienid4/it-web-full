      "sample": {
        "username": "admin",
        "action": "backup_create",
        "details": "建立系統備份 backup_20260418_091530.tar.gz",
        "timestamp": "2026-04-18T09:15:30",
        "ip_address": "<ADMIN_HOST>"
      },
      "indexes": [
        {"key": {"timestamp": -1}}
      ]
    },

    "alert_acks": {
      "_comment": "告警確認記錄",
      "sample": {
        "key": "SECSVR019_2026-04-18_063000",
        "user": "admin",
        "timestamp": "2026-04-18T10:00:00"
      }
    },

    "twgcb_results": {
